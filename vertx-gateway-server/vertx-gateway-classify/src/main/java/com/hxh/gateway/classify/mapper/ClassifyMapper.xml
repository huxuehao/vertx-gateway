<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.hxh.gateway.classify.mapper.ClassifyMapper">
    <resultMap id="treeMap" type="com.hxh.gateway.common.dto.ClientAuthTreeDto">
        <result column="id" property="id" />
        <result column="parent_id" property="parentId" />
        <result column="type" property="type" />
        <result column="online" property="online" />
        <result column="name" property="name" />
        <result column="disabled" property="disabled" />
    </resultMap>
    <select id="getTreeList" resultMap="treeMap">
        select
            id,
            parent_id,
            `name`,
            null as online,
            1 as `type`,
            0 as `disabled`
        from
            ${dbName}
        where
            del_flag = 0
    </select>

    <select id="hasChildren" resultType="int">
        select
            count(*) as num
        from ${apiDbName}
        where
            parent_id in
            <foreach collection="ids" separator="," open="(" close=")" item="id">
                #{id}
            </foreach>
            and del_flag = 0
    </select>
</mapper>
